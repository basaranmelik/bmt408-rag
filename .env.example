# ============================================================================
# Google Generative AI Configuration
# ============================================================================
# Gemini LLM (2.5-flash) ve text-embedding-004 model için API anahtarı
# Google Cloud Console'dan alın: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# Tavily Web Search Configuration
# ============================================================================
# Web search fallback için API anahtarı (RAG'den yeterli sonuç gelmediğinde)
# Tavily'den alın: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
# Database kullanıcı adı
DB_USER=anakronik

# Database şifresi (production'da güçlü bir şifre kullanın!)
DB_PASSWORD=anakronik123

# Database adı
DB_NAME=anakronik_rag

# Async SQLAlchemy bağlantı URL'si (local development için)
# Docker Compose ortamında yukarıdaki değişkenler otomatik set edilir
# Format: postgresql+asyncpg://kullaniciadi:sifre@host:port/veritabani_adi
DATABASE_URL=postgresql+asyncpg://anakronik:anakronik123@localhost:5432/anakronik_rag

# ============================================================================
# Qdrant Vector Database Configuration
# ============================================================================
# Vektör veritabanı bağlantı bilgileri (embedding storage)
# Docker Compose ortamında otomatik set edilir
QDRANT_HOST=localhost
QDRANT_PORT=6333
